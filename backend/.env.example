# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for: GPT-4o (Milo's brain) + Whisper (speech-to-text)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ElevenLabs ────────────────────────────────────────────────────────────────
# Required for: Text-to-Speech (Milo's voice in Spanish, French, Arabic, English)
# Get yours at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Auth ──────────────────────────────────────────────────────────────────────
# Secret key for signing JWT tokens (change this in production!)
JWT_SECRET=milo-dev-secret-change-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite by default, swap to PostgreSQL for production
DATABASE_URL=sqlite:///./milo.db
